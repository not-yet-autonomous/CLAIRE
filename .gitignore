# Virtual environment
.venv/

# Regenerated data files (rebuilt weekly, not tracked)
data/raw_posts.json
data/tagged_posts.json
data/synthesis_queue*.json

# Python bytecode
__pycache__/
*.pyc

# Runtime logs (no rotation yet — excluded until size is known)
logs/*.log

