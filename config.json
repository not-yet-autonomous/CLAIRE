{
  "_description": "CLAIRE pipeline configuration. Locked decisions from design phase. Change here propagates to all layers.",
  "pipeline": {
    "version": "0.1.0",
    "run_schedule": "weekly",
    "run_day": "sunday"
  },
  "ingestion": {
    "subreddits_native": [
      "ClaudeAI",
      "Anthropic"
    ],
    "subreddits_comparative": [
      "ChatGPT",
      "Gemini",
      "perplexity_ai",
      "LocalLLaMA"
    ],
    "posts_per_subreddit_hot": 100,
    "posts_per_subreddit_top_week": 50,
    "comments_per_post": 10,
    "keyword_searches": [
      "Claude frustrating",
      "Claude broken",
      "Claude wish",
      "Claude better",
      "Claude refuses",
      "Claude inconsistent",
      "Claude formatting",
      "Claude memory",
      "Claude instructions"
    ],
    "hn_search_terms": [
      "Claude AI",
      "Anthropic Claude",
      "Claude assistant",
      "Claude vs ChatGPT",
      "Claude model"
    ],
    "hn_results_per_query": 30,
    "hn_min_points": 4,
    "exclude_keywords": [
      "opus",
      "claude opus"
    ]
  },
  "triage": {
    "model": "claude-haiku-4-5-20251001",
    "batch_size": 20,
    "noise_prefilter": {
      "min_score": 5,
      "min_comments": 2,
      "logic": "AND"
    }
  },
  "cross_reference_gate": {
    "developer_persona_action": "filter_out",
    "confidence_routing": {
      "HIGH": "synthesis_queue",
      "MEDIUM": "synthesis_queue",
      "LOW": "archive",
      "IGNORE": "discard"
    },
    "friction_log_path": "data/friction_log.txt",
    "signal_keyword_map": {
      "workflow_gap": [
        "gap",
        "can't",
        "doesn't",
        "fails",
        "missing",
        "unable",
        "broken",
        "inconsistent"
      ],
      "behavior_complaint": [
        "format",
        "bullet",
        "revert",
        "ignored",
        "sycophant",
        "hedge",
        "refuse",
        "style",
        "font",
        "prose",
        "section",
        "numbering"
      ],
      "feature_praise": [
        "praise",
        "works",
        "good",
        "excellent"
      ],
      "competitor_gap": [
        "chatgpt",
        "gemini",
        "gpt",
        "openai"
      ],
      "cross_platform_workflow": [
        "prompt",
        "technique",
        "pattern",
        "workflow"
      ]
    }
  },
  "synthesis": {
    "model": "claude-sonnet-4-6",
    "evidence_threshold": 3,
    "track_a_max_batch": 50,
    "config_injection_depth": "partial",
    "hypothesis_authorship": "human",
    "locked_profile_sections": [
      "core voice",
      "humor",
      "unhinged footnote",
      "mode triggers",
      "mode syntax"
    ],
    "profile_intent_summary_path": "prompts/profile_intent_summary.txt",
    "memory_edit_list_path": "data/memory_edits_snapshot.txt",
    "track_a_cost_alert_usd": 0.65
  },
  "assembler": {
    "memory_filter_enabled": true,
    "memory_filter_model": "claude-haiku-4-5-20251001",
    "memory_filter_threshold": 0.85
  },
  "output": {
    "digest_path": "output/",
    "skill_drafts_path": "skill_drafts/",
    "archive_path": "archive/",
    "change_log_path": "data/change_log.json"
  },
  "devto": {
    "tags": [
      { "name": "anthropic",       "min_reactions": 5  },
      { "name": "claudeai",        "min_reactions": 5  },
      { "name": "claude",          "min_reactions": 5  },
      { "name": "llm",             "min_reactions": 15 },
      { "name": "aitools",         "min_reactions": 10 },
      { "name": "machinelearning", "min_reactions": 20 }
    ],
    "pages_per_tag": 2
  },
  "api_pricing": {
    "claude-haiku-4-5-20251001": {
      "input_per_mtok": 1.0,
      "output_per_mtok": 5.0
    },
    "claude-sonnet-4-6": {
      "input_per_mtok": 3.0,
      "output_per_mtok": 15.0
    }
  }
}
